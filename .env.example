SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-or-anon-key
BARANGAY_WEIGHTS_BUCKET=model-weights

# For cloud API deployments, keep startup fast and require uploaded weights.
PRELOAD_MODELS_ON_STARTUP=false
CNN_LSTM_TRAIN_IF_MISSING=false

# Set this to your frontend Render URL in production, or "*" for testing.
CORS_ORIGINS=https://your-frontend.onrender.com

# Option A: full database URL. Supabase direct Postgres needs sslmode=require.
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres?sslmode=require

# Option B: use these instead of DATABASE_URL.
# SUPABASE_DB_HOST=db.your-project.supabase.co
# SUPABASE_DB_NAME=postgres
# SUPABASE_DB_USER=postgres
# SUPABASE_DB_PASSWORD=your-password
# SUPABASE_DB_PORT=5432
